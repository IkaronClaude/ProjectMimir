# Fiesta Online game server — Linux + Wine variant
# Runs 32-bit Windows game server exes under Wine on Ubuntu 24.04.
# Same interface as Dockerfile.server: one container per process via
# PROCESS_NAME + PROCESS_EXE env vars.
#
# Usage: mimir deploy set MIMIR_OS linux
#        mimir deploy rebuild-game

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# 32-bit architecture support (game server exes are 32-bit Windows)
RUN dpkg --add-architecture i386

# Wine + ODBC (FreeTDS for SQL Server connectivity via Wine ODBC passthrough)
# wine32 provides 32-bit Wine runtime; xvfb is needed for headless Wine init.
RUN apt-get update && apt-get install -y --no-install-recommends \
        wine wine32 wine64 \
        xvfb \
        unixodbc unixodbc-dev \
        tdsodbc tdsodbc:i386 \
        libodbc2:i386 \
        wget ca-certificates \
        && rm -rf /var/lib/apt/lists/*

# Install Wine Mono (.NET support — required for GamigoZR anti-cheat service).
# Place the MSI where Wine auto-discovers it during prefix init.
RUN mkdir -p /usr/share/wine/mono && \
    wget -q https://dl.winehq.org/wine/wine-mono/9.0.0/wine-mono-9.0.0-x86.msi \
        -O /usr/share/wine/mono/wine-mono-9.0.0-x86.msi

# Register FreeTDS as the {SQL Server} ODBC driver.
# Game exes are 32-bit, so Wine's 32-bit odbc32 bridge loads 32-bit unixODBC,
# which needs the 32-bit (i386) FreeTDS driver.
RUN printf '[SQL Server]\n\
Description=FreeTDS ODBC driver for SQL Server\n\
Driver=/usr/lib/i386-linux-gnu/odbc/libtdsodbc.so\n\
Setup=/usr/lib/i386-linux-gnu/odbc/libtdsS.so\n\
FileUsage=1\n' > /etc/odbcinst.ini

# FreeTDS: map the named-instance path used in ServerInfo.txt to sqlserver:1433.
# The linux ServerInfo.txt uses SERVER=sqlserver,1433 directly (no named instance),
# but this alias serves as a fallback if old configs are used.
RUN printf '[global]\n\
    tds version = 7.4\n\
\n\
[sqlserver\\SQLEXPRESS]\n\
    host = sqlserver\n\
    port = 1433\n\
    tds version = 7.4\n' > /etc/freetds/freetds.conf

# Initialise Wine prefix (win64 supports 32-bit apps via WoW64 redirection).
# Use Xvfb for the init since wineboot may try to open windows.
ENV WINEPREFIX=/root/.wine
RUN Xvfb :99 -screen 0 800x600x24 & \
    export DISPLAY=:99 && \
    sleep 1 && \
    WINEDEBUG=-all wine wineboot --init 2>/dev/null; \
    # Use Wine's builtin odbc32.dll which bridges to system unixODBC/FreeTDS.
    # "native" would look for a Windows odbc32.dll (doesn't exist in prefix).
    WINEDEBUG=-all wine reg add 'HKCU\Software\Wine\DllOverrides' \
        /v odbc32 /t REG_SZ /d builtin /f 2>/dev/null; \
    pkill Xvfb 2>/dev/null; true

# Server process binaries are mounted as a volume at /server-bins/ (read-only).
# start-process.sh copies the needed process directory to /server/ at runtime.
# This keeps the image generic — no project-specific files baked in.
RUN mkdir -p /server

# Docker-specific ServerInfo configs (linux variant uses sqlserver,1433)
COPY config.linux/ /docker-config/

COPY scripts/start-process.sh /start-process.sh
RUN chmod +x /start-process.sh

ENV PROCESS_NAME=""
ENV PROCESS_EXE=""

CMD ["/start-process.sh"]
